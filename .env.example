# Google OAuth Client ID (crear en https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=tu-client-id-de-google.apps.googleusercontent.com

# JWT secret - usar un string aleatorio de al menos 32 caracteres
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambiar-por-string-aleatorio-de-32-caracteres

# Puerto (opcional, default: 3000)
# PORT=3000

# Ruta de la base de datos (opcional, default: toolkit.db en la raíz)
# DB_PATH=./toolkit.db
