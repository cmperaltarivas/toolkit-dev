---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ToolKit — Organizador Dev</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='0.9em' font-size='80'>🧰</text></svg>">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#FFB800">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <script is:inline>
    (function() {
      const theme = localStorage.getItem('toolkit_theme') || 'dark';
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>
</head>
<body>
<div class="app" id="app">
  <header class="header">
    <div class="header-left">
      <span class="header-sub">⏺ toolkit v3</span>
      <h1>Organizador de<br>Herramientas Dev</h1>
    </div>
    <div class="header-right">
      <button class="theme-toggle" id="themeToggle" onclick="toggleTheme()" title="Cambiar tema">
        <span id="themeIcon">🌙</span>
      </button>
      <button class="btn btn-sm btn-ghost" onclick="exportJSON()">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
        Exportar
      </button>
      <button class="btn btn-primary" onclick="openModal()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
        Nueva
      </button>
    </div>
  </header>

  <nav class="nav-tabs">
    <button class="nav-tab active" data-tab="tools" onclick="switchTab('tools')">📦 Herramientas</button>
    <button class="nav-tab" data-tab="dashboard" onclick="switchTab('dashboard')">📊 Dashboard</button>
    <button class="nav-tab" data-tab="import" onclick="switchTab('import')">📥 Importar</button>
  </nav>

  <div class="section active" id="section-tools">
      <div class="filters-panel">
        <div class="filters-row">
          <div class="fg search-group">
            <svg class="ficon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            <input type="text" class="fi" id="searchInput" placeholder="Buscar..." oninput="scheduleRender()">
          </div>
          <select class="fs" id="catFilter" onchange="handleFilterChange()"><option value="">Categoría</option></select>
          <select class="fs" id="impFilter" onchange="handleFilterChange()"><option value="">Importancia</option></select>
          <input type="text" class="fi ftag" id="tagFilter" placeholder="#tag" oninput="scheduleRender()">
          <select class="fs" id="sortFilter" onchange="handleSortChange()">
            <option value="created_at.desc">Recientes</option>
            <option value="created_at.asc">Antiguas</option>
            <option value="name.asc">A-Z</option>
            <option value="name.desc">Z-A</option>
            <option value="importance.desc">Importancia</option>
            <option value="visits.desc">Visitas</option>
          </select>
          <button class="btn btn-xs btn-ghost" onclick="toggleFavFilter()" id="favFilterBtn">⭐</button>
          <button class="btn btn-xs btn-ghost" onclick="clearFilters()" id="clearAllBtn">✕</button>
        </div>
        <div class="filters-active">
          <span class="filter-count" id="filterInfo">0 herramientas</span>
          <span id="filterChips"></span>
        </div>
      </div>
    <div class="grid" id="grid"></div>
  </div>

  <div class="section" id="section-dashboard">
    <p class="dash-desc">Resumen general de tu colección: distribución por categoría, importancia, herramientas más visitadas y tags frecuentes.</p>
    <div class="dash-grid" id="dashStats"></div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.85rem">
      <div class="dash-card"><h3>Por categoría</h3><ul class="dash-list" id="dashCat"></ul><div class="tag-expanded" id="catExpanded"></div></div>
      <div class="dash-card"><h3>Por importancia</h3><ul class="dash-list" id="dashImp"></ul></div>
    </div>
    <div class="dash-card" style="margin-top:0.85rem"><h3>Más visitadas</h3><ul class="dash-list" id="dashTop"></ul></div>
    <div class="dash-card" style="margin-top:0.85rem"><h3>Tags más usados</h3><div class="tag-cloud" id="tagCloud"></div><div class="tag-expanded" id="tagCloudExpanded"></div></div>
    <div class="dash-card" style="margin-top:0.85rem"><h3>🚫 Nunca visitadas</h3><ul class="dash-list" id="dashNunca"></ul></div>
    <div class="dash-card" style="margin-top:0.85rem"><h3>⚠️ Críticas/Esenciales sin visitar</h3><ul class="dash-list" id="dashPrio"></ul></div>
  </div>

  <div class="section" id="section-import">
    <div class="import-zone" id="importZone" onclick="document.getElementById('importFile').click()">
      <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" x2="12" y1="3" y2="15"/></svg>
      <p><strong>Subí tu archivo bookmarks.html</strong><br>Exportado de Chrome, Firefox, Edge</p>
      <p style="font-size:0.7rem;color:var(--text-dim);margin-top:0.3rem">O un archivo JSON de backup</p>
      <input type="file" id="importFile" accept=".html,.json" style="display:none" onchange="handleImport(event)">
    </div>
    <div id="importResult"></div>
  </div>
</div>

<div class="modal-overlay" id="modalOverlay">
  <div class="modal">
    <div class="modal-header">
      <h2 id="modalTitle">Nueva herramienta</h2>
      <button class="modal-close" onclick="closeModal()">&times;</button>
    </div>
    <form id="toolForm" onsubmit="saveTool(event)">
      <input type="hidden" id="editId">
      <div class="form-group">
        <label class="form-label" for="toolName">Nombre</label>
        <input type="text" class="form-input" id="toolName" required placeholder="Ej: React">
      </div>
      <div class="form-group">
        <label class="form-label" for="toolUrl">URL</label>
        <div class="url-input-wrap">
          <input type="url" class="form-input" id="toolUrl" required placeholder="https://react.dev" oninput="previewUrl(this.value)" onblur="autoDetectFavicon()">
          <div class="url-preview" id="urlPreview"></div>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label" for="toolDesc">Descripción</label>
        <textarea class="form-textarea" id="toolDesc" required placeholder="¿Para qué sirve? ¿Qué la hace útil?"></textarea>
      </div>
      <div class="form-group">
        <label class="form-label" for="toolFavicon">Icono (opcional)</label>
        <div class="favicon-row">
          <div class="url-input-wrap" style="flex:1">
            <input type="url" class="form-input" id="toolFavicon" placeholder="https://ejemplo.com/favicon.ico" oninput="previewFavicon(this.value)">
            <div class="url-preview" id="faviconPreview"></div>
          </div>
          <button type="button" class="btn btn-xs btn-ghost" onclick="detectFavicon()" title="Detectar favicon de la URL">🔍</button>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="toolCat">Categoría</label>
          <select class="form-select" id="toolCat" required></select>
        </div>
        <div class="form-group">
          <label class="form-label" for="toolImp">Importancia</label>
          <select class="form-select" id="toolImp" required></select>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label" for="tagInput">Tags</label>
        <div class="form-tags" id="tagsContainer" onclick="document.getElementById('tagInput').focus()">
          <input type="text" class="tag-input" id="tagInput" placeholder="Escribe un tag y pulsa Enter o coma" onkeydown="handleTagKey(event)" oninput="updateTagSuggestions(this.value)" autocomplete="off">
          <datalist id="tagSuggestions"></datalist>
        </div>
        <span class="form-hint">Escribe un tag y pulsa <kbd>Enter</kbd> o <kbd>,</kbd> · <kbd>Backspace</kbd> vacío borra el último · Aparecen sugerencias de tags existentes</span>
      </div>
      <div class="form-actions">
        <button type="button" class="btn btn-ghost" onclick="closeModal()">Cancelar</button>
        <button type="submit" class="btn btn-primary" id="submitBtn">Guardar</button>
      </div>
    </form>
  </div>
</div>

<div class="modal-overlay" id="confirmOverlay">
  <div class="modal confirm-modal">
    <div class="modal-header">
      <h2>Eliminar herramienta</h2>
      <button class="modal-close" onclick="closeConfirm()">&times;</button>
    </div>
    <div class="confirm-body">
      <div class="confirm-icon">
        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
      </div>
      <p class="confirm-text">¿Estás seguro de eliminar esta herramienta?</p>
      <p class="confirm-sub">No se puede deshacer</p>
    </div>
    <div class="confirm-actions">
      <button class="btn btn-ghost" onclick="closeConfirm()">Cancelar</button>
      <button class="btn btn-danger" onclick="confirmDelete()">Eliminar</button>
    </div>
  </div>
</div>

<div class="modal-overlay" id="shortcutsOverlay">
  <div class="modal shortcuts-modal">
    <div class="modal-header">
      <h2>⌨ Atajos de teclado</h2>
      <button class="modal-close" onclick="closeShortcutsHelp()">&times;</button>
    </div>
    <div class="shortcuts-list">
      <div class="shortcut-row"><span class="shortcut-key"><kbd>Ctrl</kbd> <kbd>N</kbd></span><span class="shortcut-desc">Nueva herramienta</span></div>
      <div class="shortcut-row"><span class="shortcut-key"><kbd>Ctrl</kbd> <kbd>F</kbd></span><span class="shortcut-desc">Buscar</span></div>
      <div class="shortcut-row"><span class="shortcut-key"><kbd>Esc</kbd></span><span class="shortcut-desc">Cerrar modal / popup</span></div>
      <div class="shortcut-row"><span class="shortcut-key"><kbd>?</kbd></span><span class="shortcut-desc">Mostrar esta ayuda</span></div>
    </div>
  </div>
</div>

<div class="toast-container" id="toastContainer"></div>

<script is:inline src="/scripts/store.js"></script>
<script is:inline src="/scripts/render.js"></script>
<script is:inline src="/scripts/app.js"></script>

<script is:inline>
function toggleTheme() {
  const html = document.documentElement;
  const current = html.getAttribute('data-theme') || 'dark';
  const next = current === 'dark' ? 'light' : 'dark';
  html.setAttribute('data-theme', next);
  localStorage.setItem('toolkit_theme', next);
  document.getElementById('themeIcon').textContent = next === 'dark' ? '🌙' : '☀️';
}

document.addEventListener('mousemove', e => {
  document.querySelectorAll('.card').forEach(card => {
    const rect = card.getBoundingClientRect();
    const x = ((e.clientX - rect.left) / rect.width) * 100;
    const y = ((e.clientY - rect.top) / rect.height) * 100;
    card.style.setProperty('--mouse-x', x + '%');
    card.style.setProperty('--mouse-y', y + '%');
  });
});

document.getElementById('themeIcon').textContent =
  (document.documentElement.getAttribute('data-theme') || 'dark') === 'dark' ? '🌙' : '☀️';
</script>
</body>
</html>
