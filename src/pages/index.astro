---
import '../styles/global.css';
import App from '../components/App';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ToolKit — Organizador de herramientas Dev</title>
  <meta name="description" content="Organizá tus herramientas de desarrollo. Pegá una URL y todo se completa solo. Guardá, buscá y descubrí herramientas.">
  <meta name="keywords" content="herramientas desarrollo, developer tools, react, astro, organizador">
  <meta name="author" content="ToolKit Dev">
  <link rel="canonical" href="https://toolkit.dev">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='0.9em' font-size='80'>🧰</text></svg>">
  <link rel="apple-touch-icon" href="/icons/icon-192.svg">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#FFB800">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="color-scheme" content="dark light">
  <script src="https://accounts.google.com/gsi/client" async defer></script>
  <script is:inline>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js', { scope: '/' }).catch(() => {});
      });
    }
  </script>
  <script is:inline>
    (function() {
      const theme = localStorage.getItem('toolkit_theme') || 'dark';
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>
</head>
<body>
  <App client:load />
  <div class="toast-container" id="toastContainer"></div>
</body>
</html>
